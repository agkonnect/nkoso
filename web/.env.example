# ============================================
# NKOSO — Environment Variables
# Copy this file to .env.local and fill in values
# ============================================

# Supabase (Required)
# Get these from: https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Paystack (Payment Processing)
# Get from: https://dashboard.paystack.com/#/settings/developers
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_test_xxxxx
PAYSTACK_SECRET_KEY=sk_test_xxxxx

# App Config
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Nkoso

# Email (Resend)
# Get from: https://resend.com
RESEND_API_KEY=re_xxxxx
EMAIL_FROM=noreply@nkoso.com

# Africa's Talking (SMS for Ghana)
# Get from: https://africastalking.com
AT_API_KEY=your-at-api-key
AT_USERNAME=sandbox

# Cloudflare Stream (Video - Phase 2)
CLOUDFLARE_ACCOUNT_ID=your-account-id
CLOUDFLARE_STREAM_TOKEN=your-stream-token

# Polygon (Blockchain Certs - Phase 2)
POLYGON_RPC_URL=https://polygon-rpc.com
CONTRACT_PRIVATE_KEY=your-deployer-private-key
CERTIFICATE_CONTRACT_ADDRESS=0x...
